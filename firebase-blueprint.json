{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "A saved timetable for a specific intake group",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "intakeName": { "type": "string" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "week": { "type": "number" },
              "startDate": { "type": "string" },
              "endDate": { "type": "string" },
              "intakeCode": { "type": "string" },
              "mode": { "type": "string" },
              "isBreak": { "type": "boolean" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "intakeName", "rows"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "User saved schedules"
    },
    "/admins/{userId}": {
      "schema": {
        "title": "Admin",
        "description": "Admin privileges",
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["super-admin", "manager"] }
        }
      },
      "description": "System administrators"
    }
  }
}
