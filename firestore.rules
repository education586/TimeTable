rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'dg2723777@gmail.com'
      );
    }
    
    // --- User Profile ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             (data.get('displayName', '') == null || data.get('displayName', '') is string) &&
             (data.get('photoURL', '') == null || data.get('photoURL', '') is string) &&
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().get('createdAt', request.time) == request.time;
      allow update: if isOwner(userId) && 
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().get('createdAt', existing().get('createdAt', request.time)) == existing().get('createdAt', request.time) &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'phone', 'studentId', 'weekDetails']);

      // --- Schedules ---
      function isValidSchedule(data) {
        return data.keys().hasAll(['userId', 'intakeName', 'rows', 'createdAt']) &&
               data.keys().size() == 4 &&
               data.userId == request.auth.uid &&
               data.intakeName is string && data.intakeName.size() <= 128 &&
               data.rows is list && data.rows.size() <= 200 &&
               data.createdAt == request.time;
      }

      match /schedules/{scheduleId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(scheduleId) && isValidSchedule(incoming());
        allow update: if isOwner(userId) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      // Typically schedules might be immutable or replaced entirely
                      isValidSchedule(incoming());
        allow delete: if isOwner(userId);
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
